#!/usr/bin/env bash

set -o errexit

test_dir=$(realpath "$(dirname "$0")")
. "${test_dir}/../functions"

set_debug

get_default_storageclass() {
	kubectl_bin get sc -o jsonpath='{.items[?(@.metadata.annotations.storageclass\.kubernetes\.io/is-default-class=="true")].metadata.name}'
}

ensure_default_sc_allows_expansion() {
	local default_sc
	default_sc=$(get_default_storageclass)

	echo "Checking if default storageclass ${default_sc} allows volume expansion"

	local allow_volume_expansion
	allow_volume_expansion=$(kubectl_bin get sc -o jsonpath='{.items[?(@.metadata.name=="'"${default_sc}"'")].allowVolumeExpansion}')

	if [[ ${allow_volume_expansion} != "true" ]]; then
		echo "Default storageclass ${default_sc} does not allow volume expansion"
		exit 0
	fi
}

fill_disk_to_threshold() {
	local pod=$1
	local threshold=$2
	local size_mb=$3

	echo "Filling disk on ${pod} to approximately ${threshold}% (creating ${size_mb}MB file)"

	kubectl_bin exec "${pod}" -c pxc -- bash -c "dd if=/dev/zero of=/var/lib/mysql/fillfile bs=1M count=${size_mb} 2>/dev/null || true"

	local usage
	usage=$(kubectl_bin exec "${pod}" -c pxc -- bash -c "df /var/lib/mysql | tail -1 | awk '{print \$5}' | sed 's/%//'")
	echo "Current disk usage on ${pod}: ${usage}%"
}

get_pvc_size() {
	local pvc=$1
	kubectl_bin get pvc "${pvc}" -o jsonpath='{.status.capacity.storage}'
}

wait_for_auto_resize() {
	local pvc=$1
	local expected_size=$2
	local max_retry=${3:-60}
	local sleep_time=${4:-10}

	echo "Waiting for PVC ${pvc} to auto-resize to ${expected_size}"

	local retry=0
	until [[ $(get_pvc_size "${pvc}") == "${expected_size}" ]]; do
		if [[ $retry -ge $max_retry ]]; then
			echo
			echo "PVC ${pvc} did not resize to ${expected_size}, max retries exceeded"
			kubectl_bin get pvc "${pvc}" -o yaml
			exit 1
		fi
		echo -n "."
		sleep "$sleep_time"
		retry=$((retry + 1))
	done

	echo
	echo "PVC ${pvc} successfully resized to ${expected_size}"
}

check_autoscaling_status() {
	local cluster=$1
	local expected_resize_count=$2
	shift 2
	local pvc_names=("$@")
	local max_retry=${max_retry:-30}
	local sleep_time=${sleep_time:-10}

	echo "Checking autoscaling status for PVCs: ${pvc_names[*]}"
	echo "Expected resize count per PVC: ${expected_resize_count}"

	for pvc_name in "${pvc_names[@]}"; do
		local retry=0
		until [[ $(kubectl_bin get pxc "${cluster}" -o json | jq -r --arg pvc_name "${pvc_name}" '.status.storageAutoscaling[$pvc_name].resizeCount // 0') -eq ${expected_resize_count} ]]; do
			if [[ $retry -ge $max_retry ]]; then
				echo
				echo "ERROR: PVC ${pvc_name} resize count did not reach ${expected_resize_count}, max retries exceeded"
				kubectl_bin get pxc "${cluster}" -o jsonpath='{.status.storageAutoscaling}' | jq .
				exit 1
			fi
			echo -n "."
			sleep "$sleep_time"
			retry=$((retry + 1))
		done
	done
}

apply_resourcequota() {
	local quota=$1
	local sc

	if [[ $EKS == 1 || -n ${OPENSHIFT} ]]; then
		sc='gp2-resizable'
	else
		sc=$(get_default_storageclass)
	fi

	echo "Applying resourcequota for default storageclass ${sc} with quota ${quota}"

	cat "${test_dir}/conf/resourcequota.yml" \
		| sed "s/STORAGECLASS/${sc}/" \
		| sed "s/QUOTA/${quota}/" \
		| kubectl_bin apply -f -
}

main() {
	if [[ $EKS == 1 || -n ${OPENSHIFT} ]]; then
		echo "EKS/OpenShift environment detected, creating storageclass for EBS volumes"
		kubectl_bin apply -f "${test_dir}/conf/eks-storageclass.yml"
	else
		ensure_default_sc_allows_expansion
	fi

	create_infra "${namespace}"

	cluster="some-name"

	desc 'create PXC cluster with storage autoscaling enabled'
	if [[ $EKS == 1 || -n ${OPENSHIFT} ]]; then
		spinup_pxc "${cluster}" "${test_dir}/conf/${cluster}-eks.yml" "3" "10" "${conf_dir}/secrets.yml"
	else
		spinup_pxc "${cluster}" "${test_dir}/conf/${cluster}.yml" "3" "10" "${conf_dir}/secrets.yml"
	fi

	pxc_pvcs=(
		"datadir-${cluster}-pxc-0"
		"datadir-${cluster}-pxc-1"
		"datadir-${cluster}-pxc-2"
	)

	desc 'verify initial PVC size is 1Gi'
	initial_size=$(get_pvc_size "${pxc_pvcs[0]}")
	echo "Initial PVC size: ${initial_size}"

	if [[ ${initial_size} != "1Gi" ]]; then
		echo "ERROR: Initial PVC size should be 1Gi, got ${initial_size}"
		exit 1
	fi

	desc 'fill disk to trigger autoscaling threshold 50 percent'
	# 1Gi = 1024MB, we want to fill to ~60% to trigger the 50% threshold.
	fill_disk_to_threshold "${cluster}-pxc-0" 50 600

	desc 'wait for auto-resize to trigger'
	wait_for_auto_resize "${pxc_pvcs[0]}" "3Gi" 60 10
	wait_for_auto_resize "${pxc_pvcs[1]}" "3Gi" 60 10
	wait_for_auto_resize "${pxc_pvcs[2]}" "3Gi" 60 10

	desc 'verify autoscaling status is updated'
	check_autoscaling_status "${cluster}" 1 "${pxc_pvcs[@]}"

	desc 'wait for cluster consistency after resize'
	wait_cluster_consistency "${cluster}" 3 2

	desc 'verify cluster is ready'
	kubectl_bin get pxc "${cluster}" -o jsonpath='{.status.state}' | grep -q "ready"

	if [[ -n ${OPENSHIFT} || $EKS == 1 ]]; then
		# On AWS (OpenShift/EKS), EBS volumes can only be expanded once every 6 hours.
		# Skip the multi-resize quota and maxSize tests since they require
		# multiple sequential resizes of the same volume.
		echo "OpenShift/AWS environment detected, skipping multi-resize tests (EBS rate limit)"
		destroy "${namespace}"
		desc "test passed"
		exit 0
	fi

	desc 'test namespace resource quota enforcement'
	# The cluster has 3 replicas with 3Gi PVCs = 9Gi total.
	apply_resourcequota 9Gi

	echo "Filling disk again to trigger autoscaling with quota limit"
	fill_disk_to_threshold "${cluster}-pxc-0" 50 1700

	echo "Waiting to verify PVC does not resize beyond quota (should stay at 3Gi)"
	sleep 30
	current_size=$(get_pvc_size "${pxc_pvcs[0]}")
	if [[ ${current_size} != "3Gi" ]]; then
		echo "ERROR: PVC size is ${current_size}, expected to stay at 3Gi due to quota"
		exit 1
	fi

	desc 'increase quota to allow further autoscaling'
	# Now increase quota to allow next resize step (3 replicas * 5Gi = 15Gi).
	apply_resourcequota 15Gi
	wait_for_auto_resize "${pxc_pvcs[0]}" "5Gi" 60 10
	wait_for_auto_resize "${pxc_pvcs[1]}" "5Gi" 60 10
	wait_for_auto_resize "${pxc_pvcs[2]}" "5Gi" 60 10

	desc 'verify autoscaling status after quota test'
	check_autoscaling_status "${cluster}" 2 "${pxc_pvcs[@]}"

	desc 'verify cluster consistency after quota test'
	wait_cluster_consistency "${cluster}" 3 2

	desc 'test maxSize limit'
	# Increase quota to allow maxSize testing (3 replicas * 10Gi maxSize = 30Gi).
	apply_resourcequota 30Gi
	echo "Continuing to fill disk to test maxSize enforcement"
	fill_disk_to_threshold "${cluster}-pxc-0" 50 2900
	wait_for_auto_resize "${pxc_pvcs[0]}" "7Gi" 60 10
	wait_for_auto_resize "${pxc_pvcs[1]}" "7Gi" 60 10
	wait_for_auto_resize "${pxc_pvcs[2]}" "7Gi" 60 10

	fill_disk_to_threshold "${cluster}-pxc-0" 50 4000
	wait_for_auto_resize "${pxc_pvcs[0]}" "9Gi" 60 10
	wait_for_auto_resize "${pxc_pvcs[1]}" "9Gi" 60 10
	wait_for_auto_resize "${pxc_pvcs[2]}" "9Gi" 60 10

	fill_disk_to_threshold "${cluster}-pxc-0" 50 5200

	final_size=$(get_pvc_size "${pxc_pvcs[0]}")
	if [[ ${final_size} == "10Gi" ]]; then
		echo "PVC correctly stopped at maxSize 10Gi"
	elif [[ ${final_size} == "9Gi" ]]; then
		echo "PVC is at 9Gi, will resize to 10Gi (maxSize)"
		wait_for_auto_resize "${pxc_pvcs[0]}" "10Gi" 60 10
		wait_for_auto_resize "${pxc_pvcs[1]}" "10Gi" 60 10
		wait_for_auto_resize "${pxc_pvcs[2]}" "10Gi" 60 10
	else
		echo "ERROR: PVC size is ${final_size}, expected 9Gi or 10Gi"
		exit 1
	fi

	desc 'verify final autoscaling status'
	check_autoscaling_status "${cluster}" 5 "${pxc_pvcs[@]}"

	wait_cluster_consistency "${cluster}" 3 2

	destroy "${namespace}"
	desc "test passed"
}

main
